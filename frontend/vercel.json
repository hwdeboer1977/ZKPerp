{
  "rewrites": [
    {
      "source": "/api/compliance/:path*",
      "destination": "http://95.179.138.191:3001/api/compliance/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/compliance/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}