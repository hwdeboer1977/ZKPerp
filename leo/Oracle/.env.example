# ZKPerp Oracle Relayer — environment variables
# Copy to .env and fill in your values

# ── Aleo — one private key per relayer node ───────────────────────────────────
# Each must be a different key, registered in zkperp_oracle.aleo roles[0/1/2]
ALEO_PRIVATE_KEY_A=APrivateKey1zkp...  # oracle node A
ALEO_PRIVATE_KEY_B=APrivateKey1zkp...  # oracle node B
ALEO_PRIVATE_KEY_C=APrivateKey1zkp...  # oracle node C

# ── Aleo network ──────────────────────────────────────────────────────────────
ALEO_ENDPOINT=https://api.explorer.provable.com/v1
ALEO_NETWORK=testnet

# ── Oracle contract ───────────────────────────────────────────────────────────
ORACLE_PROGRAM=zkperp_oracle.aleo

# ── EVM RPC (for Chainlink feeds) ─────────────────────────────────────────────
EVM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY      # BTC + ETH feeds
EVM_RPC_URL_ARB=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY  # SOL feed

# ── Polling ───────────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=15000
