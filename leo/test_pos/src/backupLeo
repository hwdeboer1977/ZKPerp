// test_pos.aleo — Standalone open_position test
// Tests position opening logic in isolation using mock_usdc_0128.aleo
// Does NOT import zkperp_v10.aleo — all logic is replicated here for devnet testing

import mock_usdc_0128.aleo;

program test_pos.aleo {

    @noupgrade
    async constructor() {}

    // ─────────────────────────────────────────────────────────────
    //  Constants (mirror zkperp_v10)
    // ─────────────────────────────────────────────────────────────
    const OPENING_FEE_BPS: u64 = 100u64;   // 0.01% — adjust to match your zkperp value

    // ─────────────────────────────────────────────────────────────
    //  Records
    // ─────────────────────────────────────────────────────────────

    record PositionSlot {
        owner: address,
        slot_id: u8,        // 0 = long, 1 = short
        is_open: bool,
        position_id: field,
        is_long: bool,
        size_usdc: u64,
        collateral_usdc: u64,
        entry_price: u64,
    }

    record LiquidationAuth {
        owner: address,       // orchestrator
        trader: address,
        slot_id: u8,
        position_id: field,
        is_long: bool,
        size_usdc: u64,
        collateral_usdc: u64,
        entry_price: u64,
    }

    // ─────────────────────────────────────────────────────────────
    //  Helper struct for position ID generation (mirrors zkperp)
    // ─────────────────────────────────────────────────────────────
    struct PositionIdInput {
        recipient: address,
        nonce: field,
        size: u64,
    }

    // ─────────────────────────────────────────────────────────────
    //  Mappings
    // ─────────────────────────────────────────────────────────────

    // Replay protection
    mapping used_nonces: field => bool;

    // Track open block height per position (for borrow fee calc)
    mapping position_open_blocks: field => u32;

    // ─────────────────────────────────────────────────────────────
    //  open_position
    //
    //  Call sequence on devnet:
    //    1. leo execute mock_usdc_0128.aleo/mint_public <trader> <amount>u128
    //    2. leo execute test_pos.aleo/issue_empty_slot   — get a PositionSlot record
    //    3. leo execute test_pos.aleo/open_position ...
    // ─────────────────────────────────────────────────────────────
    async transition open_position(
        slot: PositionSlot,             // CONSUMED — must be empty (is_open: false)
        public collateral: u128,
        public size: u64,
        public is_long: bool,
        public entry_price: u64,
        public max_slippage: u64,
        nonce: field,
        recipient: address,
        public orchestrator: address,
    ) -> (PositionSlot, LiquidationAuth, Future) {

        // Slot must be empty and owned by signer
        assert(!slot.is_open);
        assert_eq(slot.owner, self.signer);

        // Enforce slot direction: long = slot 0, short = slot 1
        let expected_slot_id: u8 = is_long ? 0u8 : 1u8;
        assert_eq(slot.slot_id, expected_slot_id);

        let collateral_u64: u64 = collateral as u64;

        // Validate leverage (size / collateral <= 20x)
        let leverage_scaled: u64 = (size * 100u64) / collateral_u64;
        assert(leverage_scaled <= 2000u64);
        assert(size >= 100u64);

        // Calculate opening fee
        let opening_fee: u64 = (size * OPENING_FEE_BPS) / 1_000_000u64;
        let collateral_after_fee: u64 = collateral_u64 - opening_fee;

        // Transfer collateral from trader to this program via mock_usdc
        let transfer_future: Future = mock_usdc_0128.aleo/transfer_from_public(
            self.signer,
            self.address,
            collateral
        );

        // Generate position ID
        let id_input: PositionIdInput = PositionIdInput {
            recipient: recipient,
            nonce: nonce,
            size: size,
        };
        let position_id: field = BHP256::hash_to_field(id_input);

        // Return filled PositionSlot to trader
        let filled_slot: PositionSlot = PositionSlot {
            owner: recipient,
            slot_id: slot.slot_id,
            is_open: true,
            position_id: position_id,
            is_long: is_long,
            size_usdc: size,
            collateral_usdc: collateral_after_fee,
            entry_price: entry_price,
        };

        // LiquidationAuth to orchestrator
        let liq_auth: LiquidationAuth = LiquidationAuth {
            owner: orchestrator,
            trader: recipient,
            slot_id: slot.slot_id,
            position_id: position_id,
            is_long: is_long,
            size_usdc: size,
            collateral_usdc: collateral_after_fee,
            entry_price: entry_price,
        };

        let f: Future = finalize_open_position(
            transfer_future,
            position_id,
            collateral_u64,
            size,
            entry_price,
            max_slippage,
            nonce,
            opening_fee,
        );

        return (filled_slot, liq_auth, f);
    }

    async function finalize_open_position(
        transfer_future: Future,
        position_id: field,
        collateral: u64,
        size: u64,
        entry_price: u64,
        max_slippage: u64,
        nonce: field,
        opening_fee: u64,
    ) {
        transfer_future.await();

        // Replay protection
        let nonce_used: bool = Mapping::get_or_use(used_nonces, nonce, false);
        assert(!nonce_used);
        Mapping::set(used_nonces, nonce, true);

        // NOTE: oracle price check is skipped here — no oracle on devnet.
        // For devnet we just accept entry_price as-is.
        // To re-enable: assert(price_diff <= max_slippage) against a seeded oracle mapping.

        // Store open block
        Mapping::set(position_open_blocks, position_id, block.height);
    }

    // ─────────────────────────────────────────────────────────────
    //  issue_empty_slot
    //  Issues an empty PositionSlot record to the caller.
    //  In zkperp_v10 these are issued at account creation —
    //  here we issue on demand for testing.
    // ─────────────────────────────────────────────────────────────
    transition issue_empty_slot(
        public slot_id: u8,   // 0 for long, 1 for short
    ) -> PositionSlot {
        // Only valid slot IDs
        assert(slot_id == 0u8 || slot_id == 1u8);

        return PositionSlot {
            owner: self.signer,
            slot_id: slot_id,
            is_open: false,
            position_id: 0field,
            is_long: slot_id == 0u8,
            size_usdc: 0u64,
            collateral_usdc: 0u64,
            entry_price: 0u64,
        };
    }
}