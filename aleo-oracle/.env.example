# ── EVM / Chainlink ──────────────────────────────────────────────────────────
# Ethereum Mainnet RPC (Alchemy, Infura, etc.)
EVM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
EVM_RPC_URL_ARB=https://arb-mainnet.g.alchemy.com/v2/_e51noiWVD5o9bd-pnoNpy6mG0PHiTaM

# ── Coordinator ───────────────────────────────────────────────────────────────
COORDINATOR_PORT=3010
COORDINATOR_URL=http://127.0.0.1:3010

# ── Relayer signing keys (secp256k1 — NOT your Aleo keys) ────────────────────
# Generate with: node -e "const {ethers}=await import('ethers'); console.log(ethers.Wallet.createRandom().privateKey)"
RELAYER_A_PK=0xaaaa...
RELAYER_B_PK=0xbbbb...
RELAYER_C_PK=0xcccc...

# Derived addresses (fill after generating keys — coordinator uses these as allowlist)
RELAYER_A_ADDR=0xAAAA...
RELAYER_B_ADDR=0xBBBB...
RELAYER_C_ADDR=0xCCCC...

# ── ZKPerp orchestrator (quorum recipient) ────────────────────────────────────
# When 2-of-3 agree, coordinator POSTs here
ZKPERP_ORCHESTRATOR_URL=http://localhost:3000
ZKPERP_ORCHESTRATOR_TOKEN=change_me

# ── Behaviour ─────────────────────────────────────────────────────────────────
# How often relayers poll (ms)
POLL_INTERVAL_MS=15000

# How long coordinator keeps a relayer entry before pruning (ms)
ENTRY_MAX_AGE_MS=60000
