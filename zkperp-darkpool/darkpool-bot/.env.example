# ── Network ────────────────────────────────────────────────────
NETWORK=testnet
API=https://api.explorer.provable.com/v1/testnet

# ── Program ────────────────────────────────────────────────────
PROGRAM_ID=zkdarkpool_v3.aleo
USDCX_ID=test_usdcx_stablecoin.aleo

# ── Operator wallet ────────────────────────────────────────────
OPERATOR_PRIVATE_KEY=APrivateKey1zk...
OPERATOR_VIEW_KEY=AViewKey1...
OPERATOR_ADDRESS=aleo1...

# ── Batch config ───────────────────────────────────────────────
BATCH_BLOCKS=30          # blocks per batch window
POLL_INTERVAL_MS=15000   # how often to scan for new records
FEE_PER_TX=3000000       # in microcredits

# ── Start block ────────────────────────────────────────────────
# Set to the block where you deployed the contract
START_BLOCK=15574000
